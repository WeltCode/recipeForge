# Plantilla de variables de entorno de RecipeForge.
# Copia este archivo a ".env" (solo en local) o configúralas en el hosting (Render).

# Modo desarrollo: True en local, False en producción.
DEBUG=True

# Clave secreta de Django. GENERA UNA ÚNICA para producción.
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-en-produccion

# Hosts permitidos, separados por comas.
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL (Neon). Si se omite, se usa SQLite local.
# DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# CORS: orígenes del frontend permitidos en producción, separados por comas.
CORS_ALLOWED_ORIGINS=https://tu-frontend.netlify.app

# Orígenes de confianza para CSRF (frontend y backend en https), separados por comas.
CSRF_TRUSTED_ORIGINS=https://tu-frontend.netlify.app,https://tu-backend.onrender.com
